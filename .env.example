BOT_TOKEN=           # Telegram bot token from @BotFather (used by both bot AND api)
API_URL=             # Internal API URL (default: http://localhost:3000)
API_SECRET=          # Shared secret for bot-to-API auth
DATABASE_PATH=       # SQLite file path (default: ./data/life-map.db)
WEB_APP_URL=         # Public HTTPS URL for Mini App
PORT=                # API server port (default: 3000)
VITE_API_URL=        # Web app API URL (leave empty in dev — Vite proxy handles it)
